{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/quiz-dashboard/browser",
  "functions": {
    "api/ai.ts": {
      "runtime": "@vercel/node"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
